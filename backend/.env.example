# ===========================================
# AI DevOps 面试库 - 环境变量配置示例
# ===========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 修改配置值
# 3. 不要将 .env 提交到 Git！
# ===========================================

# ---------- 基础配置 ----------

# Flask 密钥（用于 session、CSRF 等）
# 生产环境必须使用强随机密钥
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# 运行环境 (development/testing/production)
FLASK_ENV=development

# ---------- 数据库配置 ----------

# 数据库连接 URL
# 格式：postgresql://用户名：密码@主机：端口/数据库名
# 开发环境
DEV_DATABASE_URL=postgresql://localhost:5432/ai_interview_dev

# 测试环境
TEST_DATABASE_URL=postgresql://localhost:5432/ai_interview_test

# 生产环境（必须设置）
# DATABASE_URL=postgresql://user:password@host:port/database

# ---------- JWT 认证配置 ----------

# JWT 密钥
# 生产环境必须使用强随机密钥
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Access Token 过期时间（小时）
JWT_ACCESS_TOKEN_HOURS=1

# Refresh Token 过期时间（天）
JWT_REFRESH_TOKEN_DAYS=30

# ---------- AI/LLM 配置 ----------

# LLM API 密钥（从服务商获取）
# OpenAI: https://platform.openai.com/api-keys
# 其他服务商：查看对应文档
LLM_API_KEY=

# LLM API 基础 URL
# OpenAI: https://api.openai.com/v1
# Azure OpenAI: https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
LLM_BASE_URL=https://api.openai.com/v1

# LLM 模型名称
# OpenAI: gpt-3.5-turbo, gpt-4, gpt-4-turbo
LLM_MODEL=gpt-3.5-turbo

# LLM 温度（0-1，越高越有创造性）
LLM_TEMPERATURE=0.7

# LLM 最大 token 数
LLM_MAX_TOKENS=1024

# ---------- 缓存配置 ----------

# 缓存类型 (memory/redis/none)
# 开发环境：memory
# 生产环境：redis
CACHE_TYPE=memory

# Redis 连接 URL（如果 CACHE_TYPE=redis）
# 格式：redis://[:password]@host:port/db
# CACHE_REDIS_URL=redis://localhost:6379/0

# 缓存默认过期时间（秒）
CACHE_DEFAULT_TIMEOUT=300

# ---------- 日志配置 ----------

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=DEBUG

# 日志文件路径（可选，不设置则输出到控制台）
# LOG_FILE=/var/log/ai_interview/app.log

# ---------- 应用配置 ----------

# 应用名称
APP_NAME=AI DevOps 面试库

# 应用版本
APP_VERSION=0.1.0

# 每页显示数量
PAGINATION_PER_PAGE=20

# 文件上传大小限制（字节）
# 16MB = 16777216
MAX_CONTENT_LENGTH=16777216

# 上传文件夹路径
UPLOAD_FOLDER=/tmp/uploads
